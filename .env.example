# Bento — Environment Variables
# Copy this file to ~/.config/bento/.env and fill in your values.
# Keys are case-insensitive — e.g. LM_STUDIO_MODEL and lm_studio_model
# are treated the same. UPPERCASE is used here by convention.
# NEVER commit real credentials to the repository.

# LM Studio (base URL is configured in config.json, only secrets go here)
LM_STUDIO_MODEL=

# Block API keys (add as needed by installed blocks)
LINEAR_API_KEY=your_key_here
